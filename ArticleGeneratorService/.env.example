# ArticleGeneratorService 环境变量示例
# 复制为 .env 并填写实际值

# 数据库：开发用 sqlite，生产用 mysql
# SQLite: sqlite:///./article_generator.db
# MySQL: mysql+pymysql://user:pass@localhost:3306/article_generator
DATABASE_URL=sqlite:///./article_generator.db

# Redis（Celery）
REDIS_URL=redis://localhost:6379/0

# 模型服务地址
LLM_SERVICE_URL=http://localhost:8001

# CORS 允许来源，多个用逗号分隔
CORS_ORIGINS=*
