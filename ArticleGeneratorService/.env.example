# ArticleGeneratorService 环境变量示例
# 复制为 .env 并填写实际值

# 数据库：开发用 sqlite，生产用 mysql
# SQLite: sqlite:///./article_generator.db
# MySQL: mysql+pymysql://user:pass@localhost:3306/article_generator
DATABASE_URL=sqlite:///./article_generator.db

# Redis（Celery）
REDIS_URL=redis://localhost:6379/0

# 模型服务地址
LLM_SERVICE_URL=http://localhost:8001

# CORS 允许来源，多个用逗号分隔
CORS_ORIGINS=http://localhost:5173

# JWT 密钥（生产环境务必修改）
JWT_SECRET=dev-secret-change-in-production

# Access Token 有效期（分钟，默认 24 小时）
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 初始管理员账号
SEED_USERNAME=admin
SEED_PASSWORD=admin123

# 爬虫共享密钥（HotspotCrawler 调用 API 时使用）
CRAWLER_API_KEY=crawler-dev-key
